      "name": "0. Health",
      "item": [
        {
          "name": "Health Check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status 200', () => pm.response.to.have.status(200));",
                  "pm.test('App name is PropertyHub', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.app).to.eql('PropertyHub');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": "{{base_url}}/../health",
            "description": "GET /health — Check if backend is running"
          }
        }
      ]
    },
