# ============================================================
# Dockerfile.dev — React Frontend (Development)
# Hot-reload via Vite dev server
# ============================================================

FROM node:20-alpine

WORKDIR /app

COPY package.json package-lock.json* yarn.lock* pnpm-lock.yaml* ./
RUN npm install

COPY . .

EXPOSE 5173

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]
