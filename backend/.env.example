# ============================================================
# .env.example — Multi-Tenant Property Information System
# Salin file ini ke .env dan sesuaikan nilainya
# JANGAN commit .env ke repository!
# ============================================================

# Application
APP_NAME=PropertyHub
APP_ENV=development
APP_PORT=8080
APP_URL=http://localhost:8080

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=propertyhub
DB_PASSWORD=propertyhub_secret
DB_NAME=propertyhub
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Jakarta

# Database Pool
DB_MAX_OPEN_CONNS=50
DB_MAX_IDLE_CONNS=10
DB_CONN_MAX_LIFETIME=30

# JWT
JWT_SECRET=change-this-to-a-256-bit-random-string-in-production
JWT_EXPIRY_HOURS=24

# Bcrypt
BCRYPT_COST=12

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:5173

# File Upload
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=5
MAX_PHOTOS_PER_LISTING=10

# Rate Limiting
RATE_LIMIT_LOGIN_PER_MINUTE=5
RATE_LIMIT_GLOBAL_PER_MINUTE=100

# Frontend (untuk WhatsApp link)
FRONTEND_URL=http://localhost:5173
PLATFORM_NAME=PropertyHub
